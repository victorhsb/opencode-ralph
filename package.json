{
    "name": "@victorhsb/opencode-ralph",
    "version": "2.1.0",
    "description": "Ralph Wiggum technique for iterative AI development loops with OpenCode",
    "main": "bin/ralph.js",
    "bin": {
        "ralph": "bin/ralph.js"
    },
    "scripts": {
        "start": "bun ralph.ts",
        "build": "bun build ralph.ts --target bun --outdir bin --no-splitting --asset-naming='[name].[ext]' && bun build ralph.ts --outfile bin/ralph --compile",
        "test": "bun test",
        "test:smoke": "bun test ./tests/ralph.test.ts",
        "typecheck": "tsc --noEmit",
        "install-local": "bun link"
    },
    "files": [
        "bin/ralph.js",
        "bin/ralph-cli-manager.skill",
        "bin/ralph-loop-plan-creator.skill",
        "ralph.ts",
        "README.md",
        "LICENSE",
        "install.sh",
        "install.ps1",
        "uninstall.sh",
        "uninstall.ps1"
    ],
    "keywords": [
        "opencode",
        "ai",
        "ralph-wiggum",
        "iterative-development",
        "automation",
        "coding-assistant",
        "llm",
        "self-correcting",
        "autonomous",
        "developer-tools",
        "cli",
        "bun",
        "typescript",
        "sdk"
    ],
    "author": "victorhsb",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/victorhsb/opencode-ralph.git"
    },
    "dependencies": {
        "@opencode-ai/sdk": "1.2.15",
        "commander": "^14.0.3",
        "fflate": "^0.8.2",
        "typescript": "^5.9.3",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/bun": "^1.3.5",
        "tsc": "^2.0.4"
    }
}
